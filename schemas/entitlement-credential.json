{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contenttelemetry.org/schemas/entitlement-credential.json",
  "title": "Entitlement credential payload (entitlement-evidence/0.1)",
  "description": "Shape of the decoded vc+jwt payload a license_ref resolves to under the entitlement evidence profile. Validates structure only; signature, status and binding checks are defined in profiles/entitlement-evidence.md and are out of jsonschema scope.",
  "type": "object",
  "required": ["issuer", "validFrom", "validUntil", "credentialSubject"],
  "properties": {
    "issuer": {
      "type": "string",
      "pattern": "^(did:web:|https://).+"
    },
    "validFrom": { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string", "format": "date-time" },
    "type": {
      "type": "array",
      "contains": { "const": "VerifiableCredential" }
    },
    "credentialStatus": {
      "type": "object",
      "required": ["type", "statusListIndex", "statusListCredential"],
      "properties": {
        "type": { "const": "BitstringStatusListEntry" },
        "statusPurpose": { "type": "string" },
        "statusListIndex": { "type": "string", "pattern": "^[0-9]+$" },
        "statusListCredential": { "type": "string", "format": "uri" }
      }
    },
    "credentialSubject": {
      "type": "object",
      "required": ["grantee", "rights", "terms_ref"],
      "anyOf": [
        { "required": ["asset"] },
        {
          "properties": {
            "scope": { "type": "object", "required": ["content"] }
          },
          "required": ["scope"]
        }
      ],
      "properties": {
        "grantee": { "type": "string", "minLength": 1 },
        "terms_ref": { "type": "string", "format": "uri" },
        "asset": {
          "type": "object",
          "required": ["sha256"],
          "properties": {
            "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "media_type": { "type": "string" }
          }
        },
        "rights": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "enum": ["train", "rag", "embed", "display", "eval", "derive", "commercial"]
          },
          "additionalProperties": {
            "type": "object",
            "required": ["granted"],
            "properties": {
              "granted": { "type": "boolean" },
              "scope": { "type": "object" }
            }
          }
        },
        "scope": {
          "type": "object",
          "properties": {
            "content": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "duration": {
              "type": "object",
              "required": ["starts", "ends"],
              "properties": {
                "starts": { "type": "string", "format": "date-time" },
                "ends": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      }
    }
  }
}
